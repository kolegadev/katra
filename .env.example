# ── Database ──
MONGODB_URI=mongodb://admin:adminpass@mongo:27017/katra?authSource=admin
DATABASE_NAME=katra

# ── Redis ──
REDIS_URL=redis:6379

# ── LLM Provider ──
# Supported: local | openai | anthropic | deepseek | google | custom
LLM_PROVIDER=local
# LLM_API_KEY=                    # Required for non-local providers
# LLM_BASE_URL=                   # For custom OpenAI-compatible endpoints
# LLM_MODEL=                      # Default model for chat

# ── Embeddings ──
# Supported: local | openai | custom
EMBEDDING_PROVIDER=local
# EMBEDDING_API_KEY=              # Required for OpenAI
# EMBEDDING_MODEL=text-embedding-3-small

# ── Object Storage (S3-compatible) ──
S3_ENDPOINT=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET_NAME=katra-assets

# ── Auth ──
# API key for authenticating agent connections
KATRA_API_KEY=katra-local-dev
# JWT secret for dashboard access (SaaS mode)
# JWT_SECRET=

# ── Server ──
PORT=9002
MCP_PORT=3100
HOST=0.0.0.0

# ── Multi-tenancy (SaaS mode only) ──
# MULTI_TENANT=true
# TENANT_ISOLATION=database        # database | collection-prefix
