# ════════════════════════════════════════════════════════════════════
#  Katra — Configuration
#  Copy this file to .env and edit as needed
# ════════════════════════════════════════════════════════════════════

# ── Data Storage ───────────────────────────────────────────────────
# Where all persistent data lives (MongoDB, Redis, MinIO).
# Default: ./data (relative to docker-compose.yml, inside Docker)
# USB:    /mnt/usb-secrets/katra (if USB stick mounted)
# Custom: any absolute path on the host
DATA_DIR=./data

# ── Network ────────────────────────────────────────────────────────
# Ports exposed to the host (for your agent to connect)
# Host ports (what your agent connects to)
HOST_MCP_PORT=3112      # MCP endpoint — point your agent here
HOST_API_PORT=9012      # Admin REST API

# Internal ports (do not change)
MCP_PORT=3100

# ── MongoDB ────────────────────────────────────────────────────────
MONGO_USER=admin
MONGO_PASS=katra-local-dev
MONGODB_URI=mongodb://admin:katra-local-dev@mongo:27017/katra?authSource=admin&retryWrites=true&w=majority
DATABASE_NAME=katra

# ── Redis ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── MinIO (S3-compatible storage for assets) ──────────────────────
S3_ENDPOINT=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=katra-local-dev
S3_REGION=us-east-1
S3_BUCKET_NAME=katra-assets
MINIO_USER=minioadmin
MINIO_PASS=katra-local-dev

# ── Authentication ────────────────────────────────────────────────
# MCP_API_KEY: required for MCP tool calls (your agent sends this)
# KATRA_API_KEY: required for admin/tenant REST API
# Generate strong keys for production!
MCP_API_KEY=katra-local-mcp-2026
KATRA_API_KEY=katra-local-admin-2026

# ── LLM & Embeddings ──────────────────────────────────────────────
# Provider: "local" (built-in) or "openai" / "anthropic" / "ollama"
LLM_PROVIDER=local
EMBEDDING_PROVIDER=local

# For OpenAI embeddings (recommended for best semantic search):
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# For Ollama (local LLM + embeddings, no API key needed):
# LLM_PROVIDER=ollama
# EMBEDDING_PROVIDER=ollama
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── Multi-Tenancy (SaaS mode) ─────────────────────────────────────
# Set to true to enable database-per-tenant isolation
MULTI_TENANT=false

# ── Server ────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=9002
MCP_PORT_INTERNAL=3100
