# ════════════════════════════════════════════════════════════════════
#  Katra — Configuration
#  Copy this file to .env and edit as needed
# ════════════════════════════════════════════════════════════════════

# ── Data Storage ───────────────────────────────────────────────────
# Where all persistent data lives (MongoDB, Redis, MinIO).
# Default: ./data (relative to docker-compose.yml)
# USB:    /mnt/usb-secrets/katra (if USB stick mounted)
# Custom: any absolute path on the host
DATA_DIR=./data

# ── Network ────────────────────────────────────────────────────────
# Ports exposed to the host (for your agent to connect)
HOST_MCP_PORT=3112      # MCP endpoint — point your agent here
HOST_API_PORT=9012      # Admin REST API + Dashboard

# Internal ports (do not change)
MCP_PORT=3100

# ── MongoDB ────────────────────────────────────────────────────────
MONGO_USER=admin
MONGO_PASS=change-me
MONGODB_URI=mongodb://admin:change-me@mongo:27017/katra?authSource=admin&retryWrites=true&w=majority
DATABASE_NAME=katra

# ── Redis ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── MinIO (S3-compatible storage for assets) ──────────────────────
S3_ENDPOINT=http://minio:9000
AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_ACCESS_KEY=change-me
S3_REGION=us-east-1
S3_BUCKET_NAME=katra-assets
MINIO_USER=change-me
MINIO_PASS=change-me

# ── Authentication ────────────────────────────────────────────────
# MCP_API_KEY: required for MCP tool calls (your agent sends this)
# KATRA_API_KEY: required for admin/tenant REST API
#
# If left unset, Katra will generate secure random keys on first startup,
# persist them in MongoDB (so they survive restarts), and print them in
# the server logs. You can then copy them into your agent's MCP config
# and watcher config.
#
# For production, set strong keys here instead of using generated ones.
# Leave the lines below commented to enable auto-generation on first boot.
#MCP_API_KEY=your-mcp-api-key-here
#KATRA_API_KEY=your-admin-api-key-here

# ── LLM Provider (for semantic extraction, auto-journaling, summaries) ──
#
# The LLM is used for: entity extraction, semantic fact distillation,
# auto-journaling, time-block summaries, and pattern detection.
#
# THREE WAYS TO CONFIGURE (pick one — no .env editing required):
#
# 1. MCP tool (agents self-configure during setup):
#    Call the `configure_llm` MCP tool with provider, api_key, base_url, model.
#    Example: configure_llm(provider="deepseek", api_key="sk-...", 
#              base_url="https://api.deepseek.com/v1", model="deepseek-v4-flash")
#
# 2. Dashboard UI:
#    Open http://localhost:9012/dashboard/ → Settings → LLM Configuration
#    Select provider, enter API key, click Save & Apply.
#
# 3. Environment variables (fallback — read on startup only):
#    Uncomment one of the blocks below. DB config (methods 1-2) overrides env.
#
# DeepSeek (recommended — affordable, high quality):
# DEEPSEEK_API_KEY=sk-your-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-v4-flash
#
# OpenAI:
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
#
# Moonshot (Kimi):
# MOONSHOT_API_KEY=sk-your-key-here
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
# MOONSHOT_MODEL=moonshot-v1-8k
#
# Ollama (local, no API key needed, runs on host):
# OLLAMA_API_KEY=ollama-no-key
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
# OLLAMA_MODEL=llama3.2

# ── Embeddings ────────────────────────────────────────────────────
#
# Embeddings are ALWAYS local — no configuration needed.
#
# Katra uses Xenova/all-MiniLM-L6-v2 (22M params, 384 dimensions, ~80MB)
# via Transformers.js (ONNX runtime). The model downloads automatically
# on first memory storage and caches in the container.
#
# The Docker image uses node:20-slim (Debian/glibc) because the ONNX
# runtime requires glibc — it does NOT work on Alpine/musl.
#
# No API key. No external service. No cost. Works offline after first download.

# ── Multi-Tenancy (SaaS mode) ─────────────────────────────────────
# Set to true to enable database-per-tenant isolation
MULTI_TENANT=false

# ── Server ────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=9002
MCP_PORT_INTERNAL=3100
